# Claude Code OAuth Token
CLAUDE_CODE_OAUTH_TOKEN=your_claude_code_oauth_token_here

# Practo Bridge API Bearer Token
PRACTO_BEARER_TOKEN=your_practo_bearer_token_here

# Webhook Authentication Token
WEBHOOK_RECEIVER_TOKEN=your_webhook_receiver_token_here

# RingAI API Key for voice agents
RINGG_API_KEY=your_ringai_api_key_here

# Optional: Claude Executable Path (if invoking local models)
CLAUDE_EXECUTABLE_PATH=your_optional_claude_executable_path_here

